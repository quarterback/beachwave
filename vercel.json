{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/client-metadata.json", "destination": "/api/client-metadata" },
    { "source": "/", "has": [{ "type": "query", "key": "room" }], "destination": "/api/room-page" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
